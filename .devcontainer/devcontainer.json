{
  "name": "RyuSim-Fuzz",
  "build": {
    "dockerfile": "Dockerfile",
    "args": {
      "REMOTE_USER": "${localEnv:USER}",
      "REMOTE_UID": "${localEnv:REMOTE_UID:1000}",
      "REMOTE_GID": "${localEnv:REMOTE_GID:1000}"
    }
  },
  "remoteUser": "${localEnv:USER}",
  "postCreateCommand": "bash scripts/setup_chimera.sh && bash scripts/setup_vloghammer.sh",
  "mounts": [
    "source=ryusim-fuzz-bashhistory-${devcontainerId},target=/commandhistory,type=volume",
    "source=ryusim-fuzz-claude-config-${devcontainerId},target=/home/${localEnv:USER}/.claude,type=volume",
    "source=${localEnv:HOME}/.config/gh,target=/home/${localEnv:USER}/.config/gh,type=bind"
  ],
  "containerEnv": {
    "SSH_AUTH_SOCK": "/tmp/vscode-ssh-auth-sock",
    "HOME": "/home/${localEnv:USER}",
    "NODE_OPTIONS": "--max-old-space-size=4096",
    "CLAUDE_CONFIG_DIR": "/home/${localEnv:USER}/.claude"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "mshr-h.veriloghdl",
        "anthropic.claude-code"
      ]
    }
  }
}
